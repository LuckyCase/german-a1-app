# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_token_here

# PostgreSQL Database URL (Supabase)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://user:password@host:5432/database

# Web App URL (for Telegram Mini App)
WEB_APP_URL=https://german-a1-webapp.onrender.com

# Admin user IDs (comma-separated Telegram user IDs)
ADMIN_IDS=

# Sentry DSN (optional — error monitoring)
SENTRY_DSN=

# Admin secret for /admin/* endpoints (Bearer token)
ADMIN_SECRET=

# Audio cache directory (default: /tmp/audio_cache)
# AUDIO_CACHE_DIR=/tmp/audio_cache

# Pronunciation check settings
PRONUN_LOCAL_ENABLED=1
PRONUN_CLOUD_ENABLED=0
PRONUN_CLOUD_PROVIDER=openai
PRONUN_CLOUD_API_KEY=
PRONUN_MIN_CONFIDENCE=0.65
PRONUN_TIMEOUT_SEC=12
PRONUN_MAX_AUDIO_BYTES=2097152
PRONUN_MIN_AUDIO_BYTES=4000
PRONUN_RATE_LIMIT_PER_HOUR=60
# Optional local Vosk model path
# PRONUN_VOSK_MODEL_PATH=models/vosk-model-small-de-0.15
