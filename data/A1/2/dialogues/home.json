    },
    {
      "role": "Anna",
      "role_ru": "Анна",
      "text": "Ja, gern. Einen Tee, bitte.",
      "text_ru": "Да, с удовольствием. Чай, пожалуйста.",
      "audio_file": "home_05.mp3"
    },
    {
      "role": "Tom",
      "role_ru": "Том",
      "text": "Komm, setz dich. Ich mache den Tee.",
      "text_ru": "Иди, садись. Я сделаю чай.",
